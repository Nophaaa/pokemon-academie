# ============================================================
#  Variables d'environnement — Twitch API (Next.js)
#  Copiez ce fichier en .env et renseignez vos valeurs.
#  Ne committez JAMAIS .env (il est dans .gitignore)
# ============================================================

# Client ID de votre application Twitch (Developer Console)
TWITCH_CLIENT_ID=

# Client Secret — utilisé côté serveur uniquement (Client Credentials)
TWITCH_CLIENT_SECRET=
